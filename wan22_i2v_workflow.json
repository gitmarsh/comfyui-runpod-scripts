{
  "1": {
    "class_type": "WanVideoTextEncodeCached",
    "inputs": {
      "model_name": "umt5_xxl_fp16.safetensors",
      "precision": "bf16",
      "positive_prompt": "beautiful cinematic video",
      "negative_prompt": "low quality, worst quality, deformed, distorted, disfigured, motion smear, motion artifacts, fused fingers, bad anatomy, weird hand, ugly",
      "quantization": "disabled",
      "use_disk_cache": true,
      "device": "gpu"
    }
  },
  "3": {
    "class_type": "WanVideoLoraSelect",
    "inputs": {
      "lora": "Wan2.2-Lightning_I2V-A14B-4steps-lora_HIGH_fp16.safetensors",
      "strength": 1.0
    }
  },
  "4": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2.2_Remix_NSFW_i2v_14b_high_lighting_v2.0.safetensors",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn",
      "load_device": "offload_device",
      "lora": ["3", 0]
    }
  },
  "5": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "wan_2.1_vae.safetensors",
      "precision": "bf16"
    }
  },
  "6": {
    "class_type": "WanVideoImageToVideoEncode",
    "inputs": {
      "width": 832,
      "height": 480,
      "num_frames": 33,
      "noise_aug_strength": 0.0,
      "start_latent_strength": 1.0,
      "end_latent_strength": 1.0,
      "force_offload": true,
      "vae": ["5", 0]
    }
  },
  "7": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["4", 0],
      "image_embeds": ["6", 0],
      "text_embeds": ["1", 0],
      "steps": 4,
      "cfg": 1.0,
      "shift": 8.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "flowmatch_distill",
      "riflex_freq_index": 0
    }
  },
  "8": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["5", 0],
      "samples": ["7", 0],
      "enable_vae_tiling": false,
      "tile_x": 80,
      "tile_y": 60,
      "tile_stride_x": 64,
      "tile_stride_y": 48
    }
  },
  "9": {
    "class_type": "SaveAnimatedWEBP",
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "wan22_i2v",
      "fps": 16.0,
      "lossless": false,
      "quality": 80,
      "method": "default"
    }
  },
  "10": {
    "class_type": "GetImageRangeFromBatch",
    "inputs": {
      "images": ["8", 0],
      "start_index": 0,
      "num_frames": 1
    }
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["10", 0],
      "filename_prefix": "wan22_preview"
    }
  }
}
